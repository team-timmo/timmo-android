<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--  Font style.  -->
    <style name="Black">
        <item name="fontFamily">@font/pretendard_black</item>
        <item name="android:includeFontPadding">false</item>
    </style>
    <style name="Bold">
        <item name="fontFamily">@font/pretendard_bold</item>
        <item name="android:includeFontPadding">false</item>
    </style>
    <style name="Medium">
        <item name="fontFamily">@font/pretendard_medium</item>
        <item name="android:includeFontPadding">false</item>
    </style>
    <style name="Regular">
        <item name="fontFamily">@font/pretendard_regular</item>
        <item name="android:includeFontPadding">false</item>
    </style>
    <style name="SemiBold">
        <item name="fontFamily">@font/pretendard_semi_bold</item>
        <item name="android:includeFontPadding">false</item>
    </style>
    <style name="Thin">
        <item name="fontFamily">@font/pretendard_thin</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <!--  Edit text style -->
    <style name="EditText"
        parent="Widget.AppCompat.EditText" >
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/pinkish_grey</item>
        <item name="fontFamily">@font/pretendard_regular</item>
        <item name="android:includeFontPadding">false</item>
    </style>
    <style name="EnterEditText"
        parent="Widget.AppCompat.EditText" >
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_3</item>
        <item name="fontFamily">@font/pretendard_regular</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <!--  Title text style -->
    <style name="TitleText">
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">@color/text_3</item>
        <item name="fontFamily">@font/pretendard_bold</item>
        <item name="android:includeFontPadding">false</item>
    </style>
    <style name="SubtitleText">
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">@color/purple_2</item>
        <item name="fontFamily">@font/pretendard_medium</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <!--  Button text style -->
    <style name="WhiteButtonText">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/white</item>
        <item name="fontFamily">@font/pretendard_bold</item>
        <item name="android:includeFontPadding">false</item>
    </style>
</resources>